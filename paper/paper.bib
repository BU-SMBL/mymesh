@article{Smeets2022b,
   abstract = {Nanomesh is a Python library that allows users to quickly and easily create 2D and 3D meshes directly from images of the object they wish to mesh. The automated workflow can preprocess and segment the picture to extract different regions and create conforming meshes of the objects. Analysis tools allow evaluating the quality of the resuting mesh and the detection of problematic regions. The resulting meshes can be exported to a variety of popular formats so that they can be used in finite element simulations. Nanomesh can be used as python library for example in Jupyter notebooks, or through dedicated online dashboards.},
   author = {Stef Smeets and Nicolas Renaud and Lars J. Corbijn van Willenswaard},
   doi = {10.21105/joss.04654},
   issn = {2475-9066},
   issue = {78},
   journal = {Journal of Open Source Software},
   month = {10},
   pages = {4654},
   publisher = {The Open Journal},
   title = {Nanomesh: A Python workflow tool for generating meshes from image data},
   volume = {7},
   url = {https://joss.theoj.org/papers/10.21105/joss.04654},
   year = {2022}
}
